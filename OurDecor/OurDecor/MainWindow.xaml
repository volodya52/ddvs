<Window x:Class="OurDecor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OurDecor"
        mc:Ignorable="d"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Image Grid.Column="0" Grid.Row="0" Source="/Assets/Images/Наш декор.png"/>

        <DockPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2">
            <Border BorderBrush="Black" BorderThickness="1">
                <ListView ItemsSource="{Binding products}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="5" BorderBrush="Black" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding IdProductTypeNavigation.Name, StringFormat={}{0} | }"/>
                                        <TextBlock Text="{Binding ProductionName, StringFormat={} {0}}"/>
                                        <TextBlock Text="{Binding MinPriceForPartner, StringFormat={}    {0:C}, ConverterCulture=ru-RU}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Articul, StringFormat={}Артикул: {0}}"/>
                                        <TextBlock Text="{Binding MinPriceForPartner, StringFormat={}Минимальная стоимость для партнера: {0:C}, ConverterCulture=ru-RU}"/>
                                        <TextBlock Text="{Binding ShirinaRulona, StringFormat={}Ширина: {0}м}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </DockPanel>

    </Grid>
</Window>
